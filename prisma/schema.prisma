// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Location {
  SHEIKH_ZAYED
  OCTOBER_6TH
  NEW_CAIRO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Property {
  id            String         @id @default(cuid())
  name          String
  description   String
  location      Location
  address       String
  pricePerNight Float
  amenities     String[]
  images        String[]
  bookings      Booking[]
  availabilities Availability[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Booking {
  id         String        @id @default(cuid())
  propertyId String
  property   Property      @relation(fields: [propertyId], references: [id])
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id])
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([propertyId])
  @@index([clientId])
}

model Availability {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  startDate  DateTime
  endDate    DateTime
  reason     String? // e.g., "Maintenance", "Owner stay"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
}
